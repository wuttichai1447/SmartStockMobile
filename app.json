{
  "expo": {
    "name": "Smart Stock ตลาด",
    "slug": "smart-stock-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1565C0"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Smart Stock Mobile needs camera access to scan product barcodes.",
        "NSPhotoLibraryUsageDescription": "Smart Stock needs photo library access to add product images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1565C0"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Smart Stock Mobile to access your camera for barcode scanning."
        }
      ],
      "expo-asset",
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "photosPermission": "อนุญาตให้แอปเข้าถึงรูปภาพเพื่อเพิ่มรูปสินค้า"
        }
      ],
      "@react-native-community/datetimepicker"
    ]
  }
}
